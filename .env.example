# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
WEBHOOK_SECRET=whsec_...

# MongoDB Atlas (https://cloud.mongodb.com)
# Replace <username>, <password>, and <cluster> with your Atlas values.
MONGO_DB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/application-management?retryWrites=true&w=majority

# Optional: override the database name (defaults to the path in MONGO_DB_URI)
# MONGO_DB_NAME=application-management

# Email (optional — used when application status changes)
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password
